@using DVSRegister.Models.CAB.Service
@using DVSRegister.Models.CAB
@using DVSRegister.BusinessLogic.Models.CAB
@model IdentityProfileViewModel

@{
    ViewData["Title"] = "Right to work: GPG 45 identity profiles for the service";
    Layout = "~/Views/Shared/_LayoutLoggedIn.cshtml";

    // Derive these once
    var hasError = !ViewData.ModelState.IsValid;   // same as (ViewData.ModelState.ErrorCount > 0)
    var isTF_04 = Model.IsTfVersion0_4;

    if (hasError)
    {
        ViewData["Title"] = "Error: " + ViewData["Title"];
    }
}

@using (Html.BeginForm("SaveSchemeGPG45", "TrustFramework0_4", FormMethod.Post))
{
    @Html.HiddenFor(m => m.FromSummaryPage, new { @Value = ViewBag.fromSummaryPage })
    @Html.HiddenFor(m => m.FromDetailsPage, new { @Value = ViewBag.fromDetailsPage })
    @Html.HiddenFor(m => m.RefererURL)
    @Html.HiddenFor(m => m.SchemeId)
    @Html.HiddenFor(m => m.SchemeName)

    <div class="govuk-width-container">
        <a href="@Model.RefererURL" class="govuk-back-link">
            Back
        </a>

        <main id="main-content" class="govuk-main-wrapper" role="main">
            <div class="govuk-grid-row">
                <div class="govuk-grid-column-two-thirds">

                    <h1 class="govuk-heading-xl">
                        @Model.SchemeName: GPG 45 identity profiles for the service
                    </h1>

                    @if (hasError)
                    {
                        @await Html.PartialAsync("~/Views/PartialViews/_ErrorSummaryView.cshtml", Model)
                    }

                    @{
                        var lowConfidenceList = Model.AvailableIdentityProfiles
                        .Where(c => !string.IsNullOrEmpty(c.IdentityProfileName) && c.IdentityProfileName.StartsWith("L", StringComparison.OrdinalIgnoreCase))
                        .OrderBy(c => c.IdentityProfileName)
                        .ToList();

                        var mediumConfidenceList = Model.AvailableIdentityProfiles
                        .Where(c => !string.IsNullOrEmpty(c.IdentityProfileName) && c.IdentityProfileName.StartsWith("M", StringComparison.OrdinalIgnoreCase))
                        .OrderBy(c => c.IdentityProfileName)
                        .ToList();

                        var highConfidenceList = Model.AvailableIdentityProfiles
                        .Where(c => !string.IsNullOrEmpty(c.IdentityProfileName) && c.IdentityProfileName.StartsWith("H", StringComparison.OrdinalIgnoreCase))
                        .OrderBy(c => c.IdentityProfileName)
                        .ToList();

                        var veryHighConfidenceList = Model.AvailableIdentityProfiles
                        .Where(c => !string.IsNullOrEmpty(c.IdentityProfileName) &&
                        c.IdentityProfileName.StartsWith("V", StringComparison.OrdinalIgnoreCase))
                        .OrderBy(c => c.IdentityProfileName)
                        .ToList();

                        var sections = new List<(string Title, IList<IdentityProfileDto> Items)>();

                        if (isTF_04)
                        {
                            sections.Add(("Low confidence", lowConfidenceList));
                        }
                        sections.Add(("Medium confidence", mediumConfidenceList));
                        sections.Add(("High confidence", highConfidenceList));
                        sections.Add(("Very high confidence", veryHighConfidenceList));

                        var startIndex = 0;
                    }

                    <p class="govuk-body">
                        You have told us that the service is certified against @Model.SchemeName.
                    </p>
                    <p class="govuk-body">
                        You should only answer this question in relation to @Model.SchemeName checks. We
                        will ask you to provide information about any other supplementary codes
                        separately.
                    </p>
                    <p class="govuk-body">
                        This must match the information on the certificate.
                    </p>

                    @{
                        var lastIndex = sections.Count - 1;
                    }

                    @for (var i = 0; i < sections.Count; i++)
                    {
                        var section = sections[i];

                        @await Html.PartialAsync("~/Views/CabService/PartialViews/_IdentityProfilesView.cshtml",
                                new Tuple<string, DVSRegister.Models.CAB.IdentityProfileViewModel, IEnumerable<IdentityProfileDto>, bool, int>(section.Title, Model, section.Items, hasError, startIndex))
                                startIndex += section.Items.Count;

                    if (i != lastIndex)
                    {
                        <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible" />
                    }
                }

                @if (Model != null && Model.IsAmendment)
                {
                    <div class="govuk-button-group">
                        <button type="submit" class="govuk-button govuk-!-margin-top-2" name="action" value="amend">Continue</button>
                        <a href="@Model.RefererURL" class="govuk-button govuk-button--secondary" role="button" draggable="false" data-module="govuk-button">
                            Cancel
                        </a>
                    </div>
                }
                else
                {
                    <div class="govuk-button-group">
                        <button type="submit" class="govuk-button govuk-!-margin-top-6" data-module="govuk-button" name="action" value="continue">
                            Continue
                        </button>
                        <button type="submit" role="link" class="govuk-button govuk-button--secondary" name="action" value="draft">
                            Save and complete later
                        </button>
                    </div>
                }

            </div>
        </div>
    </main>
</div>
}